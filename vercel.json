{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/api/docs/",
      "destination": "/api/docs",
      "permanent": false
    },
    {
      "source": "/api/v1/",
      "destination": "/api/v1",
      "permanent": false
    },
    {
      "source": "/demo",
      "destination": "/demo/popup.html",
      "permanent": false
    }
  ],
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 30
    }
  }
}
